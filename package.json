{
  "name": "drnote",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "next dev",
    "prebuild": "node scripts/refresh-catalog.mjs && node scripts/generate-redirects.mjs",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "catalog:refresh": "node scripts/refresh-catalog.mjs",
    "catalog:refresh:fixture": "node scripts/refresh-catalog.mjs --fixture",
    "catalog:dry-run": "node scripts/catalog-dry-run.mjs",
    "catalog:dry-run:fixture": "node scripts/catalog-dry-run.mjs --fixture",
    "catalog:sync": "node scripts/catalog-sync.mjs",
    "catalog:sync:fixture": "node scripts/catalog-sync.mjs --fixture",
    "catalog:verify": "node scripts/verify-catalog.mjs",
    "catalog:migrate": "npx wrangler d1 execute dn88-catalog --file=migrations/d1/001_initial.sql -c workers/dn88/wrangler.jsonc --remote",
    "medgenius:migrate": "npx wrangler d1 execute dn88-catalog --file=migrations/d1/002_medgenius.sql -c workers/dn88/wrangler.jsonc --remote",
    "medgenius:migrate:local": "npx wrangler d1 execute dn88-catalog --file=migrations/d1/002_medgenius.sql -c workers/dn88/wrangler.jsonc --local",
    "medgenius:setup": "bash scripts/medgenius-setup.sh",
    "test:catalog": "npm run test --workspace=@dn88/catalog",
    "build:catalog": "npm run build --workspace=@dn88/catalog",
    "deploy": "npm run build && wrangler pages deploy out --project-name=dn88",
    "worker:dev": "wrangler dev -c workers/dn88/wrangler.jsonc",
    "worker:deploy": "wrangler deploy -c workers/dn88/wrangler.jsonc"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@clerk/backend": "^3.11.1",
    "@clerk/clerk-react": "^5.61.8",
    "@shadcn/react": "^0.2.0",
    "@tiptap/extension-color": "^3.27.3",
    "@tiptap/extension-details": "^3.27.3",
    "@tiptap/extension-font-family": "^3.27.3",
    "@tiptap/extension-highlight": "^3.27.3",
    "@tiptap/extension-image": "^3.27.3",
    "@tiptap/extension-link": "^3.27.3",
    "@tiptap/extension-table": "^3.27.3",
    "@tiptap/extension-table-of-contents": "^3.27.3",
    "@tiptap/extension-text-align": "^3.27.3",
    "@tiptap/extension-text-style": "^3.27.3",
    "@tiptap/extension-underline": "^3.27.3",
    "@tiptap/extension-unique-id": "^3.27.3",
    "@tiptap/pm": "^3.27.3",
    "@tiptap/react": "^3.27.3",
    "@tiptap/starter-kit": "^3.27.3",
    "@tiptap/suggestion": "^3.27.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "hono": "^4.12.28",
    "lucide-react": "^1.23.0",
    "next": "16.2.10",
    "pdfjs-dist": "^4.10.38",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-resizable-panels": "^2.1.9",
    "shadcn": "^4.13.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260711.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wrangler": "^4.108.0"
  }
}
