# Copy to .env.local and fill in values. Never commit secrets.

# GitHub fine-grained PAT for the github MCP server in .cursor/mcp.json
GITHUB_PAT=github_pat_your_token_here

# Google Analytics MCP (pipx run analytics-mcp) — see .cursor/mcp.json
# Enable Analytics Admin + Data APIs, then: gcloud auth application-default login ...
GOOGLE_APPLICATION_CREDENTIALS=/path/to/application_default_credentials.json
GOOGLE_PROJECT_ID=your-gcp-project-id

# Google Analytics measurement ID (site tracking)
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-B0QJB3Q649

# Clerk — https://dashboard.clerk.com (enabled on drnote.co only, not dn88.pages.dev)
# Allowed origins in Clerk dashboard: http://localhost:3000, https://drnote.co, https://www.drnote.co
# Webhook endpoint: https://<worker-url>/api/webhooks/clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_key_here
NEXT_PUBLIC_CLERK_DOMAIN=drnote.co
CLERK_SECRET_KEY=sk_test_your_key_here
CLERK_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# DN88 Cloudflare Worker API
# Local: npm run worker:dev → http://localhost:8787
# Production: set after `npm run worker:deploy`
# Production Worker URL (served at https://api.drnote.co after deploy)
NEXT_PUBLIC_DN88_API_URL=https://api.drnote.co

# Remote catalog sync (CI / catalog-sync workflow)
CATALOG_SYNC_ORIGIN=
CATALOG_SYNC_ORIGIN_B64=
CATALOG_SYNC_TOKEN=
CATALOG_SYNC_REF=main
CATALOG_SYNC_SECRET=
CATALOG_API_URL=

# Catalog API (frontend fetches published articles from Worker)
NEXT_PUBLIC_CATALOG_API_ENABLED=true

# Local demo articles only (never in production)
DEMO_MODE=false

# AI review (Worker only)
OPENAI_API_KEY=
OPENROUTER_API_KEY=
CONTEXT_DEV_API_KEY=
ADMIN_BOOTSTRAP_IDS=

# Stripe billing (Worker)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_MONTHLY=
STRIPE_PRICE_YEARLY=
STRIPE_PRICE_STUDENT_MONTHLY=
STRIPE_PRICE_STUDENT_YEARLY=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_YEARLY=

# Cloudflare deploy (Pages + Worker)
CLOUDFLARE_API_TOKEN=your_token
CLOUDFLARE_ACCOUNT_ID=5000e0a4f0ca6dd90b08bde9dc11ccb9
